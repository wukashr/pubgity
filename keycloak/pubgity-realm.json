{
  "realm": "pubgity",
  "displayName": "Pubgity",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "userManagedAccessAllowed": true,

  "roles": {
    "realm": [
      {
        "name": "ADMIN",
        "description": "Full access — user management, all jobs, all players"
      },
      {
        "name": "MODERATOR",
        "description": "Jobs page scoped to assigned players, subject to queue size limit"
      },
      {
        "name": "USER",
        "description": "Public pages plus personal home and profile"
      }
    ]
  },

  "clients": [
    {
      "clientId": "pubgity",
      "name": "Pubgity",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "dev-client-secret",
      "redirectUris": [
        "http://localhost:8080/*"
      ],
      "webOrigins": [
        "http://localhost:8080"
      ],
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:8080/*"
      },
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "publicClient": false,
      "frontchannelLogout": true,
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "realm roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "multivalued": "true",
            "claim.name": "realm_access.roles",
            "jsonType.label": "String"
          }
        }
      ]
    }
  ],

  "users": [
    {
      "id": "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa",
      "username": "pubgity_admin",
      "firstName": "Pubgity",
      "lastName": "Admin",
      "email": "admin@pubgity.dev",
      "emailVerified": true,
      "enabled": true,
      "credentials": [
        { "type": "password", "value": "Admin1234!", "temporary": false }
      ],
      "realmRoles": ["ADMIN"],
      "clientRoles": {
        "account": ["manage-account", "manage-account-links", "view-profile"]
      }
    },
    {
      "id": "bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbbb",
      "username": "mod_alpha",
      "firstName": "Alpha",
      "lastName": "Moderator",
      "email": "mod.alpha@pubgity.dev",
      "emailVerified": true,
      "enabled": true,
      "credentials": [
        { "type": "password", "value": "Mod1234!", "temporary": false }
      ],
      "realmRoles": ["MODERATOR"],
      "clientRoles": {
        "account": ["manage-account", "manage-account-links", "view-profile"]
      }
    },
    {
      "id": "cccccccc-cccc-cccc-cccc-cccccccccccc",
      "username": "mod_beta",
      "firstName": "Beta",
      "lastName": "Moderator",
      "email": "mod.beta@pubgity.dev",
      "emailVerified": true,
